# Copy this file to .env and fill in your values
# When USE_API is false or missing, the app uses local device storage

# Set to true to connect to the backend API
EXPO_PUBLIC_USE_API=false

# Full URL to your running API server (no trailing slash)
# Local dev: http://192.168.x.x:3000  (use your machine's LAN IP, not localhost)
# Production (Tailscale Funnel): https://your-device.ts.net
EXPO_PUBLIC_API_URL=http://192.168.1.100:3000

# API key — must match API_KEY on the server
EXPO_PUBLIC_API_KEY=your-api-key-here
