{
  "name": "my-first-pro-cli-task-manager",
  "version": "1.0.0",
  "description": "Simple CLI task manager",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "add": "node app.js add",
    "list": "node app.js list",
    "done": "node app.js done",
    "test": "jest",
    "mobile:start": "cd ui/mobile && npm start",
    "mobile:ios": "cd ui/mobile && npm run ios",
    "mobile:android": "cd ui/mobile && npm run android",
    "mobile:web": "cd ui/mobile && npm run web",
    "mobile:install": "cd ui/mobile && npm install"
  },
  "dependencies": {
    "expo": "^55.0.15",
    "expo-sharing": "^55.0.18",
    "sql.js": "^1.10.0"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "author": "Martinus",
  "license": "MIT"
}
